# AWS Configuration
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=eu-central-1

# Application Configuration
ENVIRONMENT=dev
LOG_LEVEL=INFO

# API Configuration
API_BASE_URL=https://your-api-gateway-url.execute-api.region.amazonaws.com/dev
WEBSOCKET_URL=wss://your-websocket-api-url.execute-api.region.amazonaws.com/dev

# Cognito Configuration
COGNITO_USER_POOL_ID=eu-central-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=eu-central-1

# DynamoDB Configuration
DYNAMODB_TABLE=knobeln-games

# Game Configuration
GAME_START_DELAY=60  # seconds
PICK_TIMEOUT=30      # seconds

# CORS Configuration
ALLOWED_ORIGINS=https://vereinsappell.web.app,https://vereinsappell.derlarsschneider.de

# Uncomment and configure if using a custom domain
# CUSTOM_DOMAIN=api.yourdomain.com
# ACM_CERTIFICATE_ARN=arn:aws:acm:region:account-id:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
