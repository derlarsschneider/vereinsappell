{
  "default": true,
  "MD013": {
    "line_length": 120,
    "code_blocks": false,
    "tables": false
  },
  "MD024": {
    "siblings_only": true,
    "allow_different_nesting": true
  },
  "MD033": {
    "allowed_elements": [
      "br",
      "details",
      "summary",
      "img",
      "div",
      "span"
    ]
  },
  "MD034": {
    "allow_raw_html": true
  },
  "MD041": false,
  "MD045": {
    "allow_full_document_tables": true
  },
  "MD046": {
    "style": "consistent"
  },
  "MD047": {
    "require_eof": false
  },
  "MD049": {
    "style": "smart"
  },
  "MD051": {
    "check_shortcuts": true
  },
  "MD052": {
    "check_inline_link_spacing": true
  }
}
